    /**
     * Get detailed information about received items
     */
    private function getReceivedItemsDetails($filters = [])
    {
        try {
            // This is a simplified version - in a real system you'd have proper received_items tracking
            $purchases = $this->purchaseModel->getPurchases([
                'status' => ['received', 'completed', 'partially_received'],
                'date_received_from' => $filters['date_from'] ?? date('Y-m-d', strtotime('monday this week')),
                'date_received_to' => $filters['date_to'] ?? date('Y-m-d')
            ]);

            $receivedItems = [];
            foreach ($purchases as $purchase) {
                // For now, create mock items based on purchase data
                $receivedItems[] = (object) [
                    'purchase_id' => $purchase->purchase_id,
                    'purchase_number' => $purchase->purchase_number ?? 'PO-' . str_pad($purchase->purchase_id, 6, '0', STR_PAD_LEFT),
                    'supplier_name' => $purchase->supplier_name ?? 'Unknown',
                    'product_name' => 'Various Items',
                    'quantity_ordered' => $purchase->total_items ?? 0,
                    'quantity_received' => $purchase->total_items ?? 0,
                    'unit_price' => $purchase->total_amount ? ($purchase->total_amount / max($purchase->total_items, 1)) : 0,
                    'total_value' => $purchase->total_amount ?? 0,
                    'received_date' => $purchase->updated_at ?? $purchase->created_at,
                    'status' => $purchase->status
                ];
            }

            // Apply additional filters
            if (!empty($filters['supplier'])) {
                $receivedItems = array_filter($receivedItems, function ($item) use ($filters) {
                    return stripos($item->supplier_name, $filters['supplier']) !== false;
                });
            }

            return $receivedItems;
        } catch (Exception $e) {
            error_log("Error in getReceivedItemsDetails: " . $e->getMessage());
            return [];
        }
    }

    /**
     * Debug method to check pending orders
     */
    public function debug()
    {
        header('Content-Type: application/json');

        try {
            $pendingOrders = $this->purchaseModel->getPurchases([
                'status' => ['pending', 'sent', 'partially_received']
            ]);

            $result = [
                'success' => true,
                'count' => count($pendingOrders),
                'orders' => array_slice($pendingOrders, 0, 3), // First 3 orders
                'user_logged_in' => isLoggedIn(),
                'session_data' => isset($_SESSION['user_id']) ? ['user_id' => $_SESSION['user_id']] : null
            ];

            echo json_encode($result, JSON_PRETTY_PRINT);
        } catch (Exception $e) {
            echo json_encode([
                'success' => false,
                'error' => $e->getMessage()
            ]);
        }
    }

