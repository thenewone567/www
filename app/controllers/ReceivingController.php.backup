    // Helper methods for statistics
    private function getPendingReceiptsCount()
    {
        $pending = $this->purchaseModel->getPurchases([
            'status' => ['pending', 'sent']
        ]);
        return count($pending);
    }

    private function getPartialReceiptsCount()
    {
        $partial = $this->purchaseModel->getPurchases([
            'status' => ['partially_received']
        ]);
        return count($partial);
    }

    private function getCompletedTodayCount()
    {
        $completed = $this->purchaseModel->getPurchases([
            'status' => ['received', 'completed'],
            'date_received' => date('Y-m-d')
        ]);
        return count($completed);
    }

    private function getCompletedWeekCount()
    {
        $weekStart = date('Y-m-d', strtotime('monday this week'));
        $completed = $this->purchaseModel->getPurchases([
            'status' => ['received', 'completed'],
            'date_received_from' => $weekStart
