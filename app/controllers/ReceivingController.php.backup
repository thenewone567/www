    /**
     * Show receiving details for a specific purchase order
     */
    public function details($id)
    {
        $purchase = $this->purchaseModel->getPurchaseById($id);
        if (!$purchase) {
            flash('receive_message', 'Purchase order not found', 'alert-danger');
            redirect('receiving');
        }

        // Get purchase items with receiving status
        $items = $this->purchaseModel->getPurchaseItems($id);

        // Calculate receiving progress
        $totalItems = count($items);
        $receivedItems = 0;
        $partialItems = 0;

        foreach ($items as $item) {
            if (isset($item->received_quantity) && $item->received_quantity >= $item->quantity) {
                $receivedItems++;
            } elseif (isset($item->received_quantity) && $item->received_quantity > 0) {
                $partialItems++;
            }
        }

        $progress = $totalItems > 0 ? ($receivedItems / $totalItems) * 100 : 0;

        $data = [
            'title' => 'Purchase Order Details - #' . ($purchase->purchase_number ?? $id),
            'purchase' => $purchase,
            'items' => $items,
            'progress' => [
                'total' => $totalItems,
                'received' => $receivedItems,
                'partial' => $partialItems,
                'pending' => $totalItems - $receivedItems - $partialItems,
                'percentage' => round($progress, 1)
            ]
        ];

        $this->view('receiving/details', $data);
    }

    /**
     * Show receiving reports
     */
    public function reports()
    {
        $supplierModel = $this->supplierModel;

        // Get filter parameters
        $filters = [
            'report_type' => $_GET['report_type'] ?? 'summary',
            'date_from' => $_GET['date_from'] ?? date('Y-m-01'),
            'date_to' => $_GET['date_to'] ?? date('Y-m-d'),
            'supplier' => $_GET['supplier'] ?? ''
        ];

        // Get suppliers for filter dropdown
        $suppliers = $supplierModel->getSuppliers();

        // Get report data based on type
        $reportData = [];
        $stats = [];

        switch ($filters['report_type']) {
            case 'summary':
                $reportData = $this->getSummaryReportData($filters);
                break;
            case 'detailed':
                $reportData = $this->getDetailedReportData($filters);
                break;
            case 'performance':
                $reportData = $this->getPerformanceReportData($filters);
                break;
            case 'supplier':
                $reportData = $this->getSupplierReportData($filters);
                break;
        }

        // Get summary statistics
        $stats = $this->getReportStatistics($filters);

        $data = [
            'title' => 'Receiving Reports',
            'filters' => $filters,
            'suppliers' => $suppliers,
            'report_data' => $reportData,
            'stats' => $stats,
            'insights' => $this->getReportInsights($filters)
        ];

        $this->view('receiving/reports', $data);
    }

    /**
     * Export reports functionality
     */
    public function exportReport()
    {
        if (!isset($_GET['export'])) {
            redirect('receiving/reports');
        }

        $format = $_GET['export'];
        $filters = [
            'report_type' => $_GET['report_type'] ?? 'summary',
            'date_from' => $_GET['date_from'] ?? date('Y-m-01'),
            'date_to' => $_GET['date_to'] ?? date('Y-m-d'),
            'supplier' => $_GET['supplier'] ?? ''
        ];

        // Set appropriate headers
        if ($format === 'pdf') {
            header('Content-Type: application/pdf');
            header('Content-Disposition: attachment; filename="receiving_report_' . date('Y-m-d') . '.pdf"');
        } elseif ($format === 'excel') {
            header('Content-Type: application/vnd.ms-excel');
            header('Content-Disposition: attachment; filename="receiving_report_' . date('Y-m-d') . '.xls"');
        }

        // Generate export data (simplified for demo)
        echo "Receiving Report Export - " . ucfirst($format) . "\n";
        echo "Generated on: " . date('Y-m-d H:i:s') . "\n";
        echo "Report Type: " . ucfirst($filters['report_type']) . "\n";
        echo "Date Range: " . $filters['date_from'] . " to " . $filters['date_to'] . "\n";
        exit;
    }

    /**
     * Bulk operations for receiving
     */
    public function bulk()
    {
        if ($_SERVER['REQUEST_METHOD'] === 'POST') {
            $action = $_POST['bulk_action'] ?? '';
            $selectedItems = $_POST['selected_items'] ?? [];

            if (empty($selectedItems)) {
                flash('receive_message', 'Please select items to perform bulk action', 'alert-warning');
                redirect('receiving/pending');
            }

            $success = false;

            switch ($action) {
                case 'receive_all':
                    $success = $this->bulkReceiveAll($selectedItems);
                    break;
                case 'mark_delivered':
                    $success = $this->bulkMarkDelivered($selectedItems);
                    break;
                case 'assign_location':
                    $location = $_POST['bulk_location'] ?? '';
                    $success = $this->bulkAssignLocation($selectedItems, $location);
                    break;
                case 'update_condition':
                    $condition = $_POST['bulk_condition'] ?? 'good';
                    $success = $this->bulkUpdateCondition($selectedItems, $condition);
                    break;
            }

            if ($success) {
                flash('receive_message', ucfirst(str_replace('_', ' ', $action)) . ' completed successfully', 'alert-success');
            } else {
                flash('receive_message', 'Bulk operation failed. Please try again.', 'alert-danger');
            }
        }

        redirect('receiving/pending');
    }

