    /**
     * Bulk operation methods
     */
    private function bulkReceiveAll($selectedItems)
    {
        foreach ($selectedItems as $purchaseId) {
            $items = $this->purchaseModel->getPurchaseItems($purchaseId);

            foreach ($items as $item) {
                // Receive the full quantity
                $this->purchaseModel->updateReceivedQuantity($item->id, $item->quantity);
            }

            // Update purchase status
            $this->purchaseModel->updatePurchaseStatus($purchaseId, 'received');
        }

        return true;
    }

    private function bulkMarkDelivered($selectedItems)
    {
        foreach ($selectedItems as $purchaseId) {
            $this->purchaseModel->updatePurchaseStatus($purchaseId, 'delivered');
        }

        return true;
    }

