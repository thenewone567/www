            'completed' => $this->countByStatus('received', $filters['date_from'], $filters['date_to']),
            'partial' => $this->countByStatus('partially_received', $filters['date_from'], $filters['date_to']),
            'pending' => $this->countByStatus('pending', $filters['date_from'], $filters['date_to'])
        ];

        return $data;
